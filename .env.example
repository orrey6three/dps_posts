# Скопируй в .env:  cp .env.example .env

# ---------- Supabase (без дублей NEXT_PUBLIC — URL/anon пробрасываются с серверных страниц)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Аватары: бакет Storage «avatars» + колонка users.avatar_url — см. migration.sql

# ---------- Admin / сессии
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=your-jwt-secret-key-here

# ---------- Интеграции
BOT_TOKEN=change-me-bot-secret
# Карта: можно только NEXT_PUBLIC_* или только серверный ключ — см. app/page.tsx
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-api-key

# ---------- Cron: очистка голосов (GET /api/cron/votes-cleanup)
# Обязательно для вызова с бота или внешнего хостинга. Одно и то же значение — в боте как DPS_CRON_SECRET.
# Пример генерации: openssl rand -hex 32
CRON_SECRET=

# ---------- Публичный URL приложения (Stripe redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Stripe (подписка; можно как физлицо — см. dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ---------- Поддержка без Stripe (ссылка «Задонатить»: Boosty / ko-fi и т.п.)
NEXT_PUBLIC_DONATE_URL=
