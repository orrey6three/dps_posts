# Скопируй в .env:  cp .env.example .env

# ---------- Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------- Admin / сессии
ADMIN_PASSWORD=your-secure-password
JWT_SECRET=your-jwt-secret-key-here

# ---------- Интеграции
BOT_TOKEN=change-me-bot-secret
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-api-key

# ---------- Cron: очистка голосов (GET /api/cron/votes-cleanup)
# Обязательно для вызова с бота или внешнего хостинга. Одно и то же значение — в боте как DPS_CRON_SECRET.
# Пример генерации: openssl rand -hex 32
CRON_SECRET=
